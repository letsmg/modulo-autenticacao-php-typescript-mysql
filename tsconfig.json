{
  "compilerOptions": {
    // Ambiente e compatibilidade
    "target": "es2019",
    "module": "commonjs",
    "lib": [
      "es2019",
      "dom",
      "dom.iterable"          // ← ESSENCIAL para FormData.entries()
    ],

    // Diretórios de entrada/saída (usado pelo tsc)
    "rootDir": "src",
    "outDir": "dist",

    // Saídas adicionais
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    // Type checking rigoroso (mantido como você tinha)
    "strict": true,
    "noUncheckedIndexedAccess": true,
    "exactOptionalPropertyTypes": true,
    "noUncheckedSideEffectImports": true,

    // Compatibilidade com bundlers e CommonJS
    "esModuleInterop": true,
    "allowSyntheticDefaultImports": true,
    "isolatedModules": true,          // Recomendado pelo Vite
    "verbatimModuleSyntax": false,    // Mantido como você tinha
    "moduleDetection": "legacy",

    // Performance e skips
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,

    // Não precisa de JSX (seu projeto não usa React)
    // "jsx": "react-jsx" → removido
  },

  "include": [
    "src/**/*.ts",
    "src/**/*.tsx"   // caso tenha no futuro
  ],

  "exclude": [
    "node_modules",
    "dist",
    "public",
    "**/*.js"        // ignora .js se misturados com .ts
  ]
}