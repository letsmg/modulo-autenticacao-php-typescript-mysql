# Proteger listagem de diretório
Options -Indexes

# Redirecionar acesso à raiz do projeto para a pasta public
# Quando o usuário acessar http://localhost/ts/ será redirecionado para /ts/public/
RewriteEngine On
RewriteBase /ts/
RewriteRule ^$ /ts/public/ [R=302,L]

# Bloquear acesso a arquivos de configuração sensíveis (Apache 2.4)
<Files "vite.config.js">
    Require all denied
</Files>

<Files "package.json">
    Require all denied
</Files>

<Files "pnpm-lock.yaml">
    Require all denied
</Files>

<FilesMatch "\.(ts|sql)$">
    Require all denied
</FilesMatch>

# Nota: diretivas <Directory> não são permitidas em .htaccess. Para bloquear
# diretórios específicos colocamos um .htaccess dentro das pastas (ex: dist/.htaccess)
