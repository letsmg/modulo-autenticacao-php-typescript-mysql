# 1. Impede a listagem de arquivos em qualquer diretório
Options -Indexes

# 2. Define a página personalizada para o erro 403 (Acesso Proibido)
ErrorDocument 403 /ts/public/forbidden.php

# 3. (Opcional) Protege o próprio arquivo .htaccess de ser lido
<Files ".htaccess">
    Require all denied
</Files>